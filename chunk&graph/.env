# OpenAI
OPENAI_API_KEY=sk-proj-P-OPENAI_API_KEY

# Groq
GROQ_API_KEY=GROQ_API_KEY

# Optional defaults for the summarizer
SUMMARY_PROVIDER=groq
OPENAI_MODEL=gpt-5.2
GROQ_MODEL=openai/gpt-oss-120b

# Workflow toggles
WORKFLOW_ENABLE_SUMMARY=true
WORKFLOW_EMBEDDING_PROVIDER=openai
WORKFLOW_PUSH_QDRANT=true
WORKFLOW_PUSH_NEO4J=true

# Optional workflow tuning
# SUMMARY_MODEL=
# SUMMARY_API_BASE=
# WORKFLOW_SUMMARY_FORCE=false
# WORKFLOW_SUMMARY_SLEEP_SECONDS=0
# WORKFLOW_EMBEDDING_MODEL=
# WORKFLOW_EMBEDDING_API_BASE=
# WORKFLOW_EMBEDDING_BATCH_SIZE=32

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=code_chunks
QDRANT_DISTANCE=Cosine
QDRANT_BATCH_SIZE=64
# QDRANT_API_KEY=
QDRANT_RECREATE=false
QDRANT_DELETE_MISSING=true

# Neo4j
NEO4J_URL=http://localhost:7474
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
NEO4J_BATCH_SIZE=200
NEO4J_RECREATE=false
NEO4J_DELETE_MISSING=true
